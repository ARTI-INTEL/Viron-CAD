# ══════════════════════════════════════════════════════════════════════
#  VIRON CAD — Environment Variables
# ══════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# Required variables are marked  [REQUIRED]
# Recommended for production are marked  [PRODUCTION]
# Everything else is optional with safe defaults.
# ══════════════════════════════════════════════════════════════════════

# ─── Environment ─────────────────────────────────────────────────────
# Set to "production" to enable production-only checks (SSL enforcement,
# secret validation, and hide error detail from API responses).
NODE_ENV=development

# ─── Database (MySQL) ────────────────────────────────────────────────
DB_HOST=localhost               # MySQL host                          [REQUIRED]
DB_PORT=3306                    # MySQL port (default 3306)
DB_USER=root                    # MySQL user                          [REQUIRED]
DB_PASSWORD=                    # MySQL password                      [REQUIRED]
DB_NAME=viron_cad            # MySQL database name                 [REQUIRED]

# Database SSL — only needed for cloud-hosted MySQL (Aiven, PlanetScale,
# DigitalOcean, etc.). Leave disabled for local/dev.
# DB_SSL=true                     # Set to "true" to enable SSL connection
# DB_SSL_CA_PATH=./certs/ca.pem  # Path to CA certificate file (recommended)
# DB_SSL_CA=                     # Inline CA PEM (alt to CA_PATH; use \\n for line breaks)
# DB_SSL_CERT_PATH=./certs/client-cert.pem  # Client cert for mutual TLS (optional)
# DB_SSL_KEY_PATH=./certs/client-key.pem    # Client key for mutual TLS  (optional)
# DB_SSL_REJECT_UNAUTHORIZED=true           # Set to "false" to disable verification (BLOCKED in production)

# ─── HTTP Server ──────────────────────────────────────────────────────
PORT=3000                       # Express server port (default 3000)
# ALLOWED_ORIGINS=              # Comma-separated CORS origins (defaults to CLIENT_URL)
CLIENT_URL=http://localhost:5500 # Frontend URL (used for CORS fallback)

# ─── Discord OAuth ───────────────────────────────────────────────────
# Create an OAuth2 app at https://discord.com/developers/applications
# Required scopes: identify guilds email
# Redirect URI:   https://yourdomain.com/auth/discord/callback
DISCORD_CLIENT_ID=              # Discord OAuth client ID            [REQUIRED]
DISCORD_CLIENT_SECRET=          # Discord OAuth client secret        [REQUIRED]
# DISCORD_REDIRECT_URI=         # Override auto-detected redirect (auto-built from host if absent)

# ─── Roblox OAuth ────────────────────────────────────────────────────
# Create an OAuth2 app at https://create.roblox.com/dashboard/credentials
# Required scopes: openid profile
# Redirect URI:   https://yourdomain.com/auth/roblox/callback
ROBLOX_CLIENT_ID=               # Roblox OAuth client ID             [REQUIRED for Roblox link]
ROBLOX_CLIENT_SECRET=           # Roblox OAuth client secret         [REQUIRED for Roblox link]
# ROBLOX_REDIRECT_URI=         # Override auto-detected redirect (auto-built from host if absent)

# ─── JWT Sessions ────────────────────────────────────────────────────
# Generate a strong secret:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=                     # HS256 signing key                  [REQUIRED in production]
JWT_EXPIRES_IN=7d               # Token lifetime (e.g. "7d", "24h") (default "7d")

# ─── ERLC Encryption ─────────────────────────────────────────────────
# Encrypts ERLC server keys at rest in the database.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ERLC_ENCRYPTION_KEY=            # 64-char hex key for AES-256-GCM    [REQUIRED in production]

# ─── Email (SMTP) ────────────────────────────────────────────────────
# Used for sending verification codes to users.
# If not configured, codes are logged to console (dev only).
# SMTP_HOST=smtp.gmail.com       # SMTP server host
# SMTP_PORT=587                  # SMTP port (default 587)
# SMTP_SECURE=false              # "true" for TLS (port 465)
# SMTP_USER=user@gmail.com       # SMTP username
# SMTP_PASS=                     # SMTP password or app-specific password
# SMTP_FROM='"Viron CAD" <noreply@yourdomain.com>'  # From address header
